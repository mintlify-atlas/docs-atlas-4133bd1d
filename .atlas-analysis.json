  "keyFeatures": [
    "Plugin-first architecture with manifest-driven discovery and loading",
    "Permission sandbox system with declared capabilities (ui, storage, events, network, fs)",
    "Decoupled EventBus with async support, priorities, and per-plugin isolation",
    "Plugin lifecycle hooks: on_install, on_load, on_enable, on_disable, on_unload, on_update",
    "UIBridge for mounting sidebars, tabs, toolbar actions, and dialogs from plugins",
    "Isolated per-plugin storage context with read/write isolation",
    "Cross-plugin service registry for safe inter-plugin communication (IPC)",
    "Dependency resolver with embedded wheel support and pip fallback",
    "Semver API compatibility checking to prevent incompatible plugin loading",
    "Hot-reload support for plugins during development"
  ],
  "publicApiSurface": [
    "PluginBase (abstract base class all plugins must extend)",
    "PluginContext (context injected into every plugin: ui, events, storage, services, logger)",
    "UIContext.register_sidebar(widget_factory, title, icon)",
    "UIContext.register_tab(widget_factory, title)",
    "UIContext.register_toolbar_action(action_factory, tooltip)",
    "UIContext.show_dialog(dialog_factory)",
    "EventsContext.subscribe(event, handler, priority)",
    "EventsContext.emit(event, payload)",
    "EventsContext.emit_global(event, payload)",
    "StorageContext.set(key, value)",
    "StorageContext.get(key, default)",
    "StorageContext.delete(key)",
    "ServicesContext.get_service(service_id)",
    "ServicesContext.register_service(service_id, interface)",
    "PluginManager.discover()",
    "PluginManager.load_plugin(plugin_id)",
    "PluginManager.enable_plugin(plugin_id)",
    "PluginManager.disable_plugin(plugin_id)",
    "EventBus.subscribe(event, handler, plugin_id, priority)",
    "EventBus.emit(event, payload)",
    "EventBus.unsubscribe_all(plugin_id)",
    "manifest.json schema (id, name, version, entrypoint, permissions, api_compatibility, dependencies)"
  ]
